# Client target
RESOURCE_SERVER_URL=http://localhost:3000
ENDPOINT_PATH=/my-service

# Match server network
# - stellar:testnet for your own facilitator deployment
# - stellar:pubnet for hosted facilitator flow
NETWORK=stellar:testnet

# Required for stellar:pubnet. Optional on testnet.
STELLAR_RPC_URL=

# Stellar secret key used to sign payments
STELLAR_PRIVATE_KEY=
