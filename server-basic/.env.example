# Server config
PORT=3001
ROUTE_PATH=/protected
PRICE=$0.01

# Use one of:
# - Testnet/external facilitator: NETWORK=stellar:testnet and FACILITATOR_URL=http://localhost:4022
# - Pubnet/hosted facilitator: NETWORK=stellar:pubnet and FACILITATOR_URL=https://channels.openzeppelin.com/x402
NETWORK=stellar:testnet
FACILITATOR_URL=http://localhost:4022

# Required when FACILITATOR_URL is OpenZeppelin hosted facilitator
FACILITATOR_API_KEY=

# Address receiving payment
PAY_TO=
